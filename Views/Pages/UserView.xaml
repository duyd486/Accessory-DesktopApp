<UserControl x:Class="Accessory_DesktopApp.Views.Pages.UserView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Accessory_DesktopApp.Views.Pages"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="820">
    <Grid Background="White">
        <StackPanel Margin="24">
            <!-- Title -->

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Quản lý khách hàng" FontSize="22" FontWeight="Bold" />
                    <TextBlock Text="Quản lý tài khoản và quyền hạn" Foreground="#7A7A7A" Margin="0,6,0,0" />
                </StackPanel>

                <Button Style="{StaticResource PrimaryButtonStyle}" Background="Gray" Width="80" Grid.Column="1" Content="Làm mới" Padding="12,6" Margin="12,0,0,0" Command="{Binding RefreshCommand}" />
            </Grid>

            <Separator Grid.Row="1" Margin="0,16,0,20" />


            <!-- Search Card -->
            <Border
                    Style="{StaticResource StatCardStyle}"
                    Padding="16"
                    Margin="0,0,0,20"
                    Background="White"
                    CornerRadius="12">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock
                                Margin="0,0,0,6"
                                Text="Tìm kiếm"
                                FontWeight="SemiBold" />

                        <TextBox
                                Height="40"
                                Padding="10,0"
                                VerticalContentAlignment="Center"
                                Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>

                    <Button
                            Background="DimGray"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Grid.Column="1"
                            Width="120"
                            Height="40"
                            Margin="16,24,0,0"
                            VerticalAlignment="Top"
                            Command="{Binding SearchCommand}"
                            Content="Tìm kiếm" />
                </Grid>
            </Border>

            <!-- DataGrid -->
            <Border
                    Padding="10"
                    Style="{StaticResource StatCardStyle}"
                    Background="White"
                    CornerRadius="12">

                <DataGrid
                        Style="{StaticResource MinimalDataGrid}"
                        ItemsSource="{Binding FilteredCustomers}"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        HeadersVisibility="Column"
                        IsReadOnly="True"
                        FontSize="14"
                        BorderThickness="0.4"
                        GridLinesVisibility="Horizontal"
                        RowHeight="50"
                        ColumnHeaderHeight="45"
                        SelectionMode="Single">

                    <DataGrid.Columns>

                        <DataGridTextColumn
                                Width="2*"
                                Header="Người dùng"
                                Binding="{Binding name}" />

                        <DataGridTextColumn
                                Width="2*"
                                Header="Email"
                                Binding="{Binding email}" />

                        <DataGridTextColumn
                                Width="*"
                                Header="Số điện thoại"
                                Binding="{Binding phone}" />

                        <DataGridTextColumn
                                Width="2*"
                                Header="Địa chỉ"
                                Binding="{Binding address}" />

                    </DataGrid.Columns>

                </DataGrid>
            </Border>

        </StackPanel>
    </Grid>
</UserControl>
