<Window x:Class="Accessory_DesktopApp.Views.AddCategoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thêm danh mục" Height="300" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0"> 
        <TextBlock  Text="Tên danh mục" FontWeight="SemiBold" Margin="0 0 0 5"/>
        <TextBox x:Name="NameTextBox" Padding="8" BorderBrush="#ccc" BorderThickness="1"/>
        </StackPanel>

        <StackPanel Grid.Row="1">
            <TextBlock Text="Danh mục cha" FontWeight="SemiBold" Margin="0 0 0 5"/>
            <TextBox x:Name="ParentTextBox" Padding="8" BorderBrush="#ccc" BorderThickness="1"/>
        </StackPanel>
        
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Ảnh bìa" Grid.Column="0" FontWeight="SemiBold" Margin="0 0 0 5"/>
                    <TextBox  x:Name="ImagePathTextBox" BorderBrush="#ccc" 
                     BorderThickness="1" Width="240" Height="40" IsReadOnly="True"/>
                </StackPanel>
            <Button Grid.Column="1" Content="Chọn ảnh" Width="90" Height="34" Margin="8 20 0 0"
                Background="#e5e7eb" BorderThickness="0"
                Click="PickImageButton_Click"/>
        </Grid>
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 10 0 0">
            <Button Content="Huỷ" Width="80" Height="34" Margin="0 0 10 0"
                    Background="White" BorderBrush="#ccc" BorderThickness="1" Click="CancelButton_Click"/>
            <Button Content="Thêm" Width="80" Height="34"
                    Background="#3b82f6" Foreground="White" BorderThickness="0" Click="ConfirmButton_Click"/>
        </StackPanel>
        
    </Grid>
</Window>