<Window x:Class="Accessory_DesktopApp.Views.AddCategoryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Thêm danh mục"
        Height="300"
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- NAME -->
        <StackPanel Grid.Row="0">
            <TextBlock Text="Tên danh mục"
                       FontWeight="SemiBold"
                       />
            <TextBlock x:Name="ParentInfoText"
                   Text="(Sẽ tạo danh mục CHA)"
                   Foreground="#6B7280"
                       Margin="0 0 0 5"/>   
            <TextBox x:Name="NameTextBox"
                     Padding="8"
                     BorderBrush="#ccc"
                     BorderThickness="1"/>
            
        </StackPanel>

        <!-- PARENT INFO -->
        <StackPanel Grid.Row="1" Margin="0 10 0 0">
            <TextBlock Text="Chọn ảnh"
                       FontWeight="SemiBold"
                       Margin="0 0 0 5"/>
        </StackPanel>

        <!-- IMAGE -->
        <Grid Grid.Row="2" Margin="0 10 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="ImagePathTextBox"
                     BorderBrush="#ccc"
                     BorderThickness="1"
                     Height="35"
                     IsReadOnly="True"/>

            <Button Grid.Column="1"
                    Content="Chọn ảnh"
                    Width="90"
                    Margin="10 0 0 0"
                    Background="#e5e7eb"
                    BorderThickness="0"
                    Click="PickImageButton_Click"/>
        </Grid>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0 15 0 0">

            <Button Content="Huỷ"
                    Width="80"
                    Margin="0 0 10 0"
                    Background="White"
                    BorderBrush="#ccc"
                    BorderThickness="1"
                    Click="CancelButton_Click"/>

            <Button Content="Thêm"
                    Width="80"
                    Background="#3b82f6"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="6"
                    Click="ConfirmButton_Click"/>
        </StackPanel>

    </Grid>
</Window>