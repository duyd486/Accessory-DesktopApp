<Window x:Class="Accessory_DesktopApp.Views.Modals.BankingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Accessory_DesktopApp.Views.Modals"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen"
        Title="BankingWindow" Height="700" Width="400">
    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock
            FontSize="24"
            FontWeight="Bold"
            Text="Thanh toán chuyển khoản"/>

        <!-- Content -->
        <StackPanel Grid.Row="1">

            <!-- QR -->
            <Border
                Height="240"
                Margin="0,24,0,20"
                Background="White"
                CornerRadius="12"
                ClipToBounds="True">

                <Image
                    Stretch="Uniform"
                    Source="{Binding ModalQrImageUrl}" />

            </Border>

            <!-- Info -->
            <Border
                Background="White"
                CornerRadius="12"
                Padding="18">

                <StackPanel>

                    <TextBlock
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="Thông tin chuyển khoản"/>

                    <Separator Margin="0,12"/>

                    <TextBlock
                        FontWeight="SemiBold"
                        Text="Mã đơn hàng"/>

                    <TextBlock
                        Margin="0,4,0,14"
                        Text="{Binding ModalOrderCode}"/>

                    <TextBlock
                        FontWeight="SemiBold"
                        Text="Chủ tài khoản"/>

                    <TextBlock
                        Margin="0,4,0,14"
                        Text="ACCESSORY STORE"/>

                    <TextBlock
                        FontWeight="SemiBold"
                        Text="Số tiền"/>

                    <TextBlock
                        Margin="0,4,0,0"
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="#D32F2F"
                        Text="{Binding ModalTotalPrice}"/>

                </StackPanel>

            </Border>

        </StackPanel>

        <!-- Bottom -->
        <Button
            Grid.Row="2"
            Height="42"
            Margin="0,20,0,0"
            Content="Đóng"
            Click="Close_Click"/>

    </Grid>
</Window>
